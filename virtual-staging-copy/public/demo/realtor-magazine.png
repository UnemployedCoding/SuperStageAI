 154 62;--joy-palette-warning-lightChannel:252 225 194;--joy-palette-warning-darkChannel:73 43 8;--joy-palette-common-white:#FFF;--joy-palette-common-black:#000;--joy-palette-text-primary:var(--joy-palette-neutral-100, #F0F4F8);--joy-palette-text-secondary:var(--joy-palette-neutral-300, #CDD7E1);--joy-palette-text-tertiary:var(--joy-palette-neutral-400, #9FA6AD);--joy-palette-text-icon:var(--joy-palette-neutral-400, #9FA6AD);--joy-palette-background-body:var(--joy-palette-common-black, #000);--joy-palette-background-surface:var(--joy-palette-neutral-900, #0B0D0E);--joy-palette-background-popup:var(--joy-palette-common-black, #000);--joy-palette-background-level1:var(--joy-palette-neutral-800, #171A1C);--joy-palette-background-level2:var(--joy-palette-neutral-700, #32383E);--joy-palette-background-level3:var(--joy-palette-neutral-600, #555E68);--joy-palette-background-tooltip:var(--joy-palette-neutral-600, #555E68);--joy-palette-background-backdrop:rgba(var(--joy-palette-neutral-darkChannel, 251 252 254) / 0.25);--joy-palette-divider:rgba(var(--joy-palette-neutral-mainChannel, 99 107 116) / 0.16);--joy-palette-focusVisible:var(--joy-palette-primary-500, #0B6BCB);--joy-shadowRing:0 0 #000;--joy-shadowChannel:0 0 0;--joy-shadowOpacity:0.6;}</style></head><body class="__variable_ed3508"><div id="main"><style id="dg-consent-custom-style">

/* BASE SETTINGS */
:host(.dg-consent-banner.visible) {
    display: flex !important;
    justify-content: center !important;
}

:host(.dg-consent-banner) {
    border-radius: 16px !important;
    background: transparent !important;
    border-top-right-radius: 16px !important;
    border-top-left-radius: 16px !important;
    width: auto !important;
    box-shadow: none !important;
}

:host(.dg-consent-banner) .dg-app {
    border: 1px solid #e0e7f0 !important;
    background: white !important;
    grid-template-columns: 1fr 1fr 1fr !important;
    display: grid !important;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1) !important;
    max-height: none !important;
    width: 100% !important;
}

:host(.dg-bottom) .dg-app {
    border-top-right-radius: 16px !important;
    border-top-left-radius: 16px !important;
}

:host(.dg-modal) .dg-app {
    width: 100vw !important;
    height: 100vh !important;
    margin: 0 !important;
    box-sizing: border-box !important;
}

:host(.dg-modal) {
    left: 0 !important;
    right: 0 !important;
}

:host(.dg-consent-banner) .dg-app > * {
    grid-column: span 3 !important;
}

/* Typography matching original */
:host(.dg-consent-banner) .dg-main-content-explanation {
    font-size: 16px !important;
    line-height: 1.5 !important;
    color: #374151 !important; /* gray-700 */
}

/* Link styling */
:host(.dg-consent-banner) .dg-link {
    text-decoration: underline !important;
    color: #374151 !important; /* gray-700 */
}

/* Button container */
.dg-button {
    border-radius: 12px !important; /* rounded-xl */
    padding: 12px 40px !important; /* px-10 py-3 */
    font-weight: 600 !important; /* font-semibold */
    font-size: 14px !important; /* text-sm */
    transition: all 0.2s !important;
    border: 2px solid !important; /* border-2 */

    background: #2563eb !important; /* primary blue */
    color: white !important;
    border-color: #2563eb !important;
}

/* Button hover states */
.dg-button:hover {
    background: #1d4ed8 !important; /* darker blue */
    border-color: #1d4ed8 !important;
}


:host(.dg-consent-banner) .dg-slider:not(.essential-label) {
    background: #e1e1e1 !important;
}

/* RESPONSIVE SETTINGS */
@media (min-width: 768px) {
    :host(.dg-consent-banner) {
        border-bottom-left-radius: 16px !important;
        border-bottom-right-radius: 16px !important;
        bottom: 16px !important;
        transform: translateX(-50%) !important;
        left: 50% !important;
        width: 100vw !important;
        justify-items: center !important;
    }

    :host(.dg-consent-banner) .dg-app {
        max-width: 1024px !important;
    }

    :host(.dg-modal) .dg-app {
        max-height: 80vh !important;
        width: 80vw !important;
    }

    :host(.dg-bottom) .dg-app {
        border-bottom-left-radius: 16px !important;
        border-bottom-right-radius: 16px !important;
        margin: 0 16px !important;
    }

    :host(.dg-bottom) .dg-app > button {
        grid-column: span 1 !important;
    }

    :host(.dg-bottom) .dg-app > button:not(:last-child) {
        margin-right: 8px !important;
    }
}
